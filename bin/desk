#!/bin/bash

# Aether Workspace - Dynamic Desktop Engine
# Path: aether-workspace/bin/desk

VAULT_DIR="$HOME/.aether_vault"
DESKTOP_DIR="$HOME/Desktop"
PYTHON_BIN="$VAULT_DIR/venv/bin/python3"

show_help() {
    echo "Aether Workspace Control Utility"
    echo "Usage: desk [command] [args]"
    echo ""
    echo "Workspace Visibility Commands:"
    echo "  mode [all|work|study|admin|zen|none] - Switch visible desktop shortcuts"
    echo "  status                               - Display storage analytics & active dashboard"
    echo ""
    echo "Search & Notes Assistant Commands:"
    echo "  ask \"[query]\"                         - Semantic query search across academic notes/papers"
    echo "  index                                - Force update the search document index"
    echo "  digest                               - Run weekly productivity report generation"
    echo ""
    echo "Developer Storage Optimization Commands:"
    echo "  prune [project]                      - Prune node_modules/venv of stale/specified projects"
    echo "  restore [project]                    - Restore dependencies from archive for a project"
}

clear_desktop_symlinks() {
    find "$DESKTOP_DIR" -maxdepth 1 -type l -exec rm -f {} \;
}

create_symlink() {
    local target="$1"
    local link_name="$2"
    if [ -e "$target" ]; then
        ln -s "$target" "$DESKTOP_DIR/$link_name"
    else
        echo "Error: Target folder does not exist: $target"
    fi
}

set_mode() {
    local mode="$1"
    clear_desktop_symlinks
    
    case "$mode" in
        all)
            create_symlink "$VAULT_DIR/00_Inbox" "00_Inbox"
            create_symlink "$VAULT_DIR/10_GATE_Prep" "10_GATE_Prep"
            create_symlink "$VAULT_DIR/20_College_Academics" "20_College_Academics"
            create_symlink "$VAULT_DIR/30_Active_Projects" "30_Active_Projects"
            create_symlink "$VAULT_DIR/40_Resources_Reference" "40_Resources_Reference"
            create_symlink "$VAULT_DIR/50_Archive" "50_Archive"
            echo "Aether Mode: all (Workspace fully visible)"
            ;;
        work)
            create_symlink "$VAULT_DIR/30_Active_Projects" "30_Active_Projects"
            create_symlink "$VAULT_DIR/00_Inbox" "00_Inbox"
            echo "Aether Mode: work (Active software development)"
            ;;
        study)
            create_symlink "$VAULT_DIR/10_GATE_Prep" "10_GATE_Prep"
            create_symlink "$VAULT_DIR/20_College_Academics" "20_College_Academics"
            create_symlink "$VAULT_DIR/00_Inbox" "00_Inbox"
            echo "Aether Mode: study (GATE Prep & College Academics)"
            ;;
        admin)
            create_symlink "$VAULT_DIR/40_Resources_Reference/Administrative" "Administrative"
            create_symlink "$VAULT_DIR/00_Inbox" "00_Inbox"
            echo "Aether Mode: admin (Administrative & Financial Reference)"
            ;;
        zen|none)
            echo "Aether Mode: $mode (Desktop cleared of all folders)"
            ;;
        *)
            echo "Error: Unknown mode '$mode'"
            show_help
            ;;
    esac
}

# Main Command Router
case "$1" in
    "")
        show_help
        ;;
    mode)
        if [ -z "$2" ]; then
            echo "Error: Please specify a mode."
            show_help
        else
            set_mode "$2"
        fi
        ;;
    status)
        "$PYTHON_BIN" "$VAULT_DIR/aether_dashboard.py"
        ;;
    ask)
        if [ -z "$2" ]; then
            echo "Error: Please specify a search query."
        else
            shift
            "$PYTHON_BIN" "$VAULT_DIR/aether_search.py" ask "$@"
        fi
        ;;
    index)
        "$PYTHON_BIN" "$VAULT_DIR/aether_search.py" index
        ;;
    digest)
        "$PYTHON_BIN" "$VAULT_DIR/digest.py"
        ;;
    prune)
        shift
        if [ -z "$1" ]; then
            "$PYTHON_BIN" "$VAULT_DIR/aether_gc.py" prune
        else
            "$PYTHON_BIN" "$VAULT_DIR/aether_gc.py" prune "$1"
        fi
        ;;
    restore)
        if [ -z "$2" ]; then
            echo "Error: Please specify the project name to restore."
        else
            "$PYTHON_BIN" "$VAULT_DIR/aether_gc.py" restore "$2"
        fi
        ;;
    *)
        echo "Error: Unknown command '$1'"
        show_help
        ;;
esac
